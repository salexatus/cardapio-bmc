# Supabase — necessário apenas para o Painel Admin e o conteúdo dinâmico.
# Sem estas variáveis, o site funciona normalmente com os dados-semente.
# Encontre os valores em: Supabase → Project Settings → API
VITE_SUPABASE_URL=https://SEU-PROJETO.supabase.co
VITE_SUPABASE_ANON_KEY=sua-anon-public-key
